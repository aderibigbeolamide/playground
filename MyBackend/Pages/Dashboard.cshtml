@page
@model MyBackend.Pages.DashboardModel
@{
    ViewData["Title"] = "Statistics Dashboard";
    Layout = "_Layout";
}

<section id="dashboard-section" class="dashboard-container animate-slide-up">
    <!-- User Welcome Bar -->
    <div class="welcome-bar">
        <div class="user-profile">
            <div class="user-avatar">
                @(Model.Username.Substring(0, Math.Min(Model.Username.Length, 2)).ToUpper())
            </div>
            <div class="user-info">
                <h3>Welcome back, @Model.Username!</h3>
                <p class="subtitle">@Model.Email</p>
            </div>
        </div>
        
        <form method="post" asp-page="/Logout">
            <button type="submit" class="btn btn-logout">
                <i data-lucide="log-out"></i>
                <span>Sign Out</span>
            </button>
        </form>
    </div>

    <!-- KPI Grid -->
    <div class="stats-grid">
        <!-- KPI 1: Total Users -->
        <div class="stat-card">
            <div class="stat-card-header">
                <span class="stat-label">Total Registered</span>
                <div class="stat-icon icon-users">
                    <i data-lucide="users"></i>
                </div>
            </div>
            <div class="stat-value">@Model.TotalUsers</div>
            <div class="stat-desc">Platform User Base</div>
        </div>

        <!-- KPI 2: Active Sessions -->
        <div class="stat-card">
            <div class="stat-card-header">
                <span class="stat-label">Active Sessions</span>
                <div class="stat-icon icon-active">
                    <i data-lucide="activity"></i>
                </div>
            </div>
            <div class="stat-value">@Model.ActiveSessions</div>
            <div class="stat-desc">Live Authentication Keys</div>
        </div>

        <!-- KPI 3: Daily Growth -->
        <div class="stat-card">
            <div class="stat-card-header">
                <span class="stat-label">Signups Today</span>
                <div class="stat-icon icon-growth">
                    <i data-lucide="user-plus"></i>
                </div>
            </div>
            <div class="stat-value">@Model.NewSignupsToday</div>
            <div class="stat-desc">Registrations in last 24h</div>
        </div>

        <!-- KPI 4: Active Ratio -->
        <div class="stat-card">
            <div class="stat-card-header">
                <span class="stat-label">Active Users Ratio</span>
                <div class="stat-icon icon-ratio">
                    <i data-lucide="percent"></i>
                </div>
            </div>
            <div class="stat-value-group">
                <div class="stat-value">@Model.ActivePercentage%</div>
                <div class="progress-bar-container">
                    <div class="progress-bar" style="width: @Model.ActivePercentage%"></div>
                </div>
            </div>
            <div class="stat-desc">Percentage of live users</div>
        </div>

        <!-- KPI 5: DB Health -->
        <div class="stat-card">
            <div class="stat-card-header">
                <span class="stat-label">Database Latency</span>
                <div class="stat-icon icon-health">
                    <i data-lucide="database"></i>
                </div>
            </div>
            <div class="stat-value">@Model.DbResponseTimeMs ms</div>
            <div class="stat-desc">SQL Query Latency</div>
        </div>
    </div>

    <!-- Charts and Details Grid -->
    <div class="dashboard-details-grid">
        <!-- Left: Signup Trend Chart Card (Rendered Server-side) -->
        <div class="panel panel-chart">
            <div class="panel-header-row">
                <div class="panel-header">
                    <i data-lucide="line-chart" class="icon-accent"></i>
                    <h2>Registration Trend (7 Days)</h2>
                </div>
            </div>
            <div class="chart-container">
                <div id="signup-trend-chart" class="svg-chart-wrapper">
                    <svg width="100%" height="100%" viewBox="0 0 500 220" preserveAspectRatio="none" style="overflow: visible;">
                        <!-- Defs for Gradient Shading -->
                        <defs>
                            <linearGradient id="chart-gradient" x1="0" y1="0" x2="1" y2="0">
                                <stop offset="0%" stop-color="#6366f1" />
                                <stop offset="50%" stop-color="#3b82f6" />
                                <stop offset="100%" stop-color="#8b5cf6" />
                            </linearGradient>
                            <linearGradient id="area-gradient" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="#6366f1" stop-opacity="0.25" />
                                <stop offset="100%" stop-color="#6366f1" stop-opacity="0.0" />
                            </linearGradient>
                        </defs>

                        <!-- Horizontal Grid Lines -->
                        <line x1="40" y1="30" x2="480" y2="30" class="chart-grid-line" />
                        <line x1="40" y1="80" x2="480" y2="80" class="chart-grid-line" />
                        <line x1="40" y1="130" x2="480" y2="130" class="chart-grid-line" />
                        <line x1="40" y1="180" x2="480" y2="180" class="chart-axis-line" />

                        <!-- Area & Line Path Rendered directly from C# Model -->
                        @if (!string.IsNullOrEmpty(Model.AreaPath))
                        {
                            <path d="@Model.AreaPath" class="chart-area" />
                            <path d="@Model.LinePath" class="chart-line" fill="none" />
                        }

                        <!-- Interactive Point dots -->
                        @foreach (var p in Model.SvgPoints)
                        {
                            <circle cx="@p.X" cy="@p.Y" r="5" class="chart-point" data-date="@p.FullDate" data-count="@p.Count" />
                            @Html.Raw($"<text x=\"{p.X:F1}\" y=\"{(p.Y - 10):F1}\" class=\"chart-label-value\" text-anchor=\"middle\">{p.Count}</text>")
                            @Html.Raw($"<text x=\"{p.X:F1}\" y=\"200\" class=\"chart-label\" text-anchor=\"middle\">{p.ShortDate}</text>")
                        }
                    </svg>
                </div>
            </div>
        </div>

        <!-- Right: Quick Stats Log Table -->
        <div class="panel panel-log">
            <div class="panel-header">
                <i data-lucide="table" class="icon-accent"></i>
                <h2>Trend Logs</h2>
            </div>
            <div class="log-table-wrapper">
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Registered Users</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.SignupTrend)
                        {
                            <tr>
                                <td>@item.Date</td>
                                <td style="font-weight: 600;">@item.Count users</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Attach tooltips to server-rendered dots
            const dots = document.querySelectorAll('.chart-point');
            dots.forEach(dot => {
                dot.addEventListener('click', (e) => {
                    const count = e.target.getAttribute('data-count');
                    const date = e.target.getAttribute('data-date');
                    
                    // Display a temporary toast notification when clicking a chart point
                    showToast(`${date}: ${count} users registered`);
                });
            });

            // Toast helper function
            function showToast(message) {
                const toastContainer = document.getElementById('toast-container');
                const toast = document.createElement('div');
                toast.className = 'toast toast-success';
                toast.innerHTML = `
                    <i data-lucide="check-circle"></i>
                    <span>${message}</span>
                `;
                toastContainer.appendChild(toast);
                lucide.createIcons();
                
                setTimeout(() => {
                    toast.style.animation = 'fade-in 0.3s ease reverse forwards';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            }
        });
    </script>
}
